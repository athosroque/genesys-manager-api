# Ambiente e Região
ENVIRONMENT=development
COOKIE_DOMAIN=localhost
CORS_ORIGINS=http://localhost:5173

# Genesys Cloud Credentials
# Obtenha em: Admin > Integrations > OAuth
GENESYS_CLIENT_ID=seu_client_id_aqui
GENESYS_CLIENT_SECRET=seu_client_secret_aqui
GENESYS_REGION=sae1.pure.cloud

# Autenticação Local (JWT)
# Gere uma chave segura com: openssl rand -hex 32
JWT_SECRET_KEY=sua_chave_secreta_aqui
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
